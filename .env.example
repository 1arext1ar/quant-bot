# Copy this file to .env and fill in your MetaTrader 5 credentials.
# Use a demo account first, then a live account only after validation.
MT5_TERMINAL_PATH=C:/Program Files/MetaTrader 5/terminal64.exe
MT5_LOGIN=00000000
MT5_PASSWORD=your_password_here
MT5_SERVER=your_server_here
MT5_SYMBOL=EURUSD
MT5_TIMEFRAME=H1
RISK_PER_TRADE=0.01
MAX_DAILY_LOSS=0.02
MAX_DAILY_DRAWDOWN=0.05
MAX_OPEN_POSITIONS=3
